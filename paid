-- ==============================================================
--  АВТОНОМНЫЙ AUTO GUN (телепорт к пистолету и возврат на место)
--  Работает даже после смерти (ждёт респавна)
--  Глобальные функции: _G.GrabGun, _G.GrabAndShootMurderer, _G.AutoGrabGun, _G.GunSystem
-- ==============================================================

_G.GunSystem = {
    AutoGrabEnabled = true,
    GunDropCheckInterval = 1,
    ActiveGunDrops = {}
}

local mapPaths = {
    "ResearchFacility", "Hospital3", "MilBase", "House2", "Workplace",
    "Mansion2", "BioLab", "Hotel", "Factory", "Bank2", "PoliceStation"
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

-- Сканирование карты
local function ScanForGunDrops()
    _G.GunSystem.ActiveGunDrops = {}
    for _, mapName in ipairs(mapPaths) do
        local map = Workspace:FindFirstChild(mapName)
        if map then
            local gunDrop = map:FindFirstChild("GunDrop")
            if gunDrop then
                table.insert(_G.GunSystem.ActiveGunDrops, gunDrop)
            end
        end
    end
    local rootGunDrop = Workspace:FindFirstChild("GunDrop")
    if rootGunDrop then
        table.insert(_G.GunSystem.ActiveGunDrops, rootGunDrop)
    end
    -- print("[Auto Gun] Найдено пистолетов: " .. #_G.GunSystem.ActiveGunDrops)
end

-- Экипировка пистолета
local function EquipGun()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Gun") then
        return true
    end
    local gun = LocalPlayer.Backpack:FindFirstChild("Gun")
    if gun then
        gun.Parent = LocalPlayer.Character
        task.wait(0.1)
        return LocalPlayer.Character:FindFirstChild("Gun") ~= nil
    end
    return false
end

-- Подобрать пистолет (с телепортом и возвратом)
function _G.GrabGun(gunDrop)
    if not LocalPlayer.Character then
        -- print("[Auto Gun] Персонаж отсутствует, ждём респавна...")
        LocalPlayer.CharacterAdded:Wait()
        -- print("[Auto Gun] Персонаж появился, продолжаем.")
    end

    local character = LocalPlayer.Character
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        -- print("[Auto Gun] Нет HumanoidRootPart")
        return false
    end

    -- Запоминаем исходное положение и ориентацию
    local originalCFrame = rootPart.CFrame

    if not gunDrop then
        ScanForGunDrops()
        if #_G.GunSystem.ActiveGunDrops == 0 then
            -- print("[Auto Gun] Пистолетов на карте нет")
            return false
        end
        local nearestGun = nil
        local minDistance = math.huge
        for _, drop in ipairs(_G.GunSystem.ActiveGunDrops) do
            local distance = (rootPart.Position - drop.Position).Magnitude
            if distance < minDistance then
                nearestGun = drop
                minDistance = distance
            end
        end
        gunDrop = nearestGun
    end

    if gunDrop then
        -- Телепорт к пистолету
        rootPart.CFrame = gunDrop.CFrame
        task.wait(0.2)

        -- Нажимаем ProximityPrompt
        local prompt = gunDrop:FindFirstChildOfClass("ProximityPrompt")
        if prompt then
            fireproximityprompt(prompt)
            -- print("[Auto Gun] Пистолет успешно взят!")
            task.wait(0.2)
        else
            -- print("[Auto Gun] У пистолета нет ProximityPrompt")
        end

        -- Возвращаемся на исходную позицию (если персонаж всё ещё существует)
        if LocalPlayer.Character and rootPart and rootPart.Parent then
            rootPart.CFrame = originalCFrame
            -- print("[Auto Gun] Возврат на исходную позицию")
        end
        return true
    end
    return false
end

-- Автоматический сбор (цикл)
function _G.AutoGrabGun()
    while _G.GunSystem.AutoGrabEnabled do
        if not LocalPlayer.Character then
            -- print("[Auto Gun] Персонаж мёртв, ждём респавна...")
            LocalPlayer.CharacterAdded:Wait()
            -- print("[Auto Gun] Респавн произошёл, продолжаем.")
        end
        ScanForGunDrops()
        if #_G.GunSystem.ActiveGunDrops > 0 and LocalPlayer.Character then
            local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local nearestGun = nil
                local minDistance = math.huge
                for _, drop in ipairs(_G.GunSystem.ActiveGunDrops) do
                    local distance = (rootPart.Position - drop.Position).Magnitude
                    if distance < minDistance then
                        nearestGun = drop
                        minDistance = distance
                    end
                end
                if nearestGun then
                    local originalCFrame = rootPart.CFrame
                    rootPart.CFrame = nearestGun.CFrame
                    task.wait(0.2)
                    local prompt = nearestGun:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        fireproximityprompt(prompt)
                        -- print("[Auto Gun] Авто-сбор: пистолет подобран")
                        task.wait(0.2)
                    end
                    if LocalPlayer.Character and rootPart and rootPart.Parent then
                        rootPart.CFrame = originalCFrame
                    end
                end
            end
        end
        task.wait(_G.GunSystem.GunDropCheckInterval)
    end
end

-- Найти убийцу
local function GetMurderer()
    local getPlayerData = ReplicatedStorage:FindFirstChild("GetPlayerData", true)
    if not getPlayerData then return nil end
    local success, roles = pcall(function() return getPlayerData:InvokeServer() end)
    if not success or not roles then return nil end
    for playerName, data in pairs(roles) do
        if data.Role == "Murderer" then
            return Players:FindFirstChild(playerName)
        end
    end
    return nil
end

-- Взять пистолет и выстрелить в убийцу (с возвратом)
function _G.GrabAndShootMurderer()
    if not LocalPlayer.Character then
        -- print("[Auto Gun] Персонаж отсутствует, ждём...")
        LocalPlayer.CharacterAdded:Wait()
    end

    if not (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Gun")) then
        if not _G.GrabGun() then
            -- print("[Auto Gun] Не удалось взять пистолет")
            return
        end
        task.wait(0.1)
    end

    if not EquipGun() then
        -- print("[Auto Gun] Не удалось экипировать пистолет")
        return
    end

    local murderer = GetMurderer()
    if not murderer or not murderer.Character then
        -- print("[Auto Gun] Убийца не найден")
        return
    end

    local targetRoot = murderer.Character:FindFirstChild("HumanoidRootPart")
    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if targetRoot and localRoot then
        local originalCFrame = localRoot.CFrame
        localRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, -4)
        task.wait(0.1)

        local gun = LocalPlayer.Character:FindFirstChild("Gun")
        if gun and gun:FindFirstChild("KnifeLocal") then
            local targetPart = murderer.Character:FindFirstChild("HumanoidRootPart")
            if targetPart then
                local args = {[1] = 1, [2] = targetPart.Position, [3] = "AH2"}
                local createBeam = gun.KnifeLocal:FindFirstChild("CreateBeam")
                if createBeam and createBeam:IsA("RemoteFunction") then
                    createBeam:InvokeServer(unpack(args))
                    -- print("[Auto Gun] Выстрел в убийцу!")
                end
            end
        end
        if LocalPlayer.Character and localRoot and localRoot.Parent then
            localRoot.CFrame = originalCFrame
        end
    end
end

-- Мониторинг появления пистолета
local notifiedGunDrops = {}
local function checkForGunDrops()
    for _, mapName in ipairs(mapPaths) do
        local map = Workspace:FindFirstChild(mapName)
        if map then
            local gunDrop = map:FindFirstChild("GunDrop")
            if gunDrop and not notifiedGunDrops[gunDrop] then
                -- print("[Auto Gun] Пистолет появился на карте: " .. mapName)
                notifiedGunDrops[gunDrop] = true
            end
        end
    end
end

local function setupGunDropMonitoring()
    for _, mapName in ipairs(mapPaths) do
        local map = Workspace:FindFirstChild(mapName)
        if map then
            if map:FindFirstChild("GunDrop") then
                checkForGunDrops()
            end
            map.ChildAdded:Connect(function(child)
                if child.Name == "GunDrop" then
                    task.wait(0.5)
                    checkForGunDrops()
                end
            end)
            map.ChildRemoved:Connect(function(child)
                if child.Name == "GunDrop" and notifiedGunDrops[child] then
                    notifiedGunDrops[child] = nil
                end
            end)
        end
    end
    Workspace.ChildAdded:Connect(function(child)
        if table.find(mapPaths, child.Name) then
            task.wait(2)
            checkForGunDrops()
        end
    end)
end
setupGunDropMonitoring()

