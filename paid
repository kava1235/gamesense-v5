    local function clampDropdownPosition(dropdownFrame, mainFrame, triggerFrame)
        if not mainFrame then return end
        task.wait()
        for iteration = 1, 3 do
            local absX = dropdownFrame.AbsolutePosition.X
            local absY = dropdownFrame.AbsolutePosition.Y
            local sizeX = dropdownFrame.AbsoluteSize.X
            local sizeY = dropdownFrame.AbsoluteSize.Y
            local frameAbsPos = mainFrame.AbsolutePosition
            local frameAbsSize = mainFrame.AbsoluteSize
            local newX = dropdownFrame.Position.X.Offset
            local newY = dropdownFrame.Position.Y.Offset
            local changed = false
            if absX + sizeX > frameAbsPos.X + frameAbsSize.X then
                newX = newX - ((absX + sizeX) - (frameAbsPos.X + frameAbsSize.X))
                changed = true
            end
            if absX < frameAbsPos.X then
                newX = newX + (frameAbsPos.X - absX)
                changed = true
            end
            if triggerFrame then
                local triggerAbsY = triggerFrame.AbsolutePosition.Y
                local triggerHeight = triggerFrame.AbsoluteSize.Y
                local spaceBelow = (frameAbsPos.Y + frameAbsSize.Y) - (triggerAbsY + triggerHeight)
                local spaceAbove = triggerAbsY - frameAbsPos.Y
                if spaceBelow < sizeY then
                    if spaceAbove >= sizeY then
                        newY = newY - (sizeY + triggerHeight)
                    else
                        newY = newY - (sizeY - spaceBelow)
                    end
                    changed = true
                end
            end
            if changed then
                dropdownFrame.Position = UDim2.new(0, newX, 0, newY)
                task.wait()
            else
                break
            end
        end
    end

