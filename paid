-- ==========================================
-- ESP ИГРОКОВ (УПРАВЛЯЕТСЯ ЧЕРЕЗ _G.ESPEnabled)
-- ==========================================
local RunService = game:GetService("RunService")
local PlayersService = game:GetService("Players")
local Camera = workspace.CurrentCamera
local LocalPlayer = PlayersService.LocalPlayer

local Roles_Cache = {}
local ESP_Cache = {}
local MAX_DISTANCE = 400

local function HasCharacter(Player)
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") and Player.Character:FindFirstChild("Head")
end

local function GetPlayerColor(Player)
    if Roles_Cache[Player] then
        return Roles_Cache[Player]
    end

    local Character = Player.Character
    local Backpack = Player:FindFirstChild("Backpack")
    local isMurderer = false
    local isSheriff = false

    if Backpack then
        if Backpack:FindFirstChild("Knife") or Backpack:FindFirstChild("Blade") then isMurderer = true end
        if Backpack:FindFirstChild("Gun") or Backpack:FindFirstChild("Revolver") then isSheriff = true end
    end

    if Character then
        if Character:FindFirstChild("Knife") or Character:FindFirstChild("Blade") or Character:FindFirstChild("RealKnife") then isMurderer = true end
        if Character:FindFirstChild("Gun") or Character:FindFirstChild("Revolver") then isSheriff = true end
    end

    if isMurderer then
        Roles_Cache[Player] = Color3.fromRGB(255, 0, 50)
        return Roles_Cache[Player]
    elseif isSheriff then
        Roles_Cache[Player] = Color3.fromRGB(0, 195, 255)
    end

    return Color3.fromRGB(0, 255, 100)
end

local function createDrawing(class, properties)
    local obj = Drawing.new(class)
    for prop, val in pairs(properties) do
        obj[prop] = val
    end
    return obj
end

local function CreateESPContainer()
    local box = { Main = {}, Outline = {} }
    for i = 1, 8 do
        box.Main[i] = createDrawing("Line", {Thickness = 2.5, ZIndex = 4, Visible = false})
        box.Outline[i] = createDrawing("Line", {Thickness = 5.0, Color = Color3.fromRGB(0, 0, 0), ZIndex = 1, Visible = false})
    end
    return box
end

local function HidePlayerESP(box)
    for i = 1, 8 do
        if box.Main[i] then box.Main[i].Visible = false end
        if box.Outline[i] then box.Outline[i].Visible = false end
    end
end

local function RemoveESP(Player)
    if ESP_Cache[Player] then
        local box = ESP_Cache[Player]
        for i = 1, 8 do
            if box.Main[i] then box.Main[i]:Remove() end
            if box.Outline[i] then box.Outline[i]:Remove() end
        end
        ESP_Cache[Player] = nil
        Roles_Cache[Player] = nil
    end
end

local function UpdateESP()
    if not _G.ESPEnabled then
        for _, Player in pairs(PlayersService:GetPlayers()) do
            if ESP_Cache[Player] then
                HidePlayerESP(ESP_Cache[Player])
            end
        end
        return
    end

    for _, Player in pairs(PlayersService:GetPlayers()) do
        if Player == LocalPlayer then continue end
        
        local success, err = pcall(function()
            if HasCharacter(Player) then
                if not ESP_Cache[Player] then
                    ESP_Cache[Player] = CreateESPContainer()
                end
                
                local box = ESP_Cache[Player]
                local Character = Player.Character
                local HRP = Character.HumanoidRootPart
                local Head = Character.Head
                
                local Distance = (Camera.CFrame.Position - HRP.Position).Magnitude
                if Distance > MAX_DISTANCE then
                    HidePlayerESP(box)
                    return
                end
                
                local TopWorld = Head.Position + Vector3.new(0, 1.2, 0)
                local BottomWorld = HRP.Position - Vector3.new(0, 3, 0)
                
                local TopScreen, TopOnScreen = Camera:WorldToViewportPoint(TopWorld)
                local BottomScreen, BottomOnScreen = Camera:WorldToViewportPoint(BottomWorld)
                
                if TopOnScreen and BottomOnScreen then
                    local Height = math.clamp(math.abs(TopScreen.Y - BottomScreen.Y), 10, Camera.ViewportSize.Y)
                    local Width = Height * 0.55
                    
                    local X = TopScreen.X - Width / 2
                    local Y = TopScreen.Y
                    
                    local color = GetPlayerColor(Player)
                    local length = Width / 3.5
                    
                    local lines = {
                        {From = Vector2.new(X, Y), To = Vector2.new(X + length, Y)},
                        {From = Vector2.new(X, Y), To = Vector2.new(X, Y + length)},
                        {From = Vector2.new(X + Width, Y), To = Vector2.new(X + Width - length, Y)},
                        {From = Vector2.new(X + Width, Y), To = Vector2.new(X + Width, Y + length)},
                        {From = Vector2.new(X, Y + Height), To = Vector2.new(X + length, Y + Height)},
                        {From = Vector2.new(X, Y + Height), To = Vector2.new(X, Y + Height - length)},
                        {From = Vector2.new(X + Width, Y + Height), To = Vector2.new(X + Width - length, Y + Height)},
                        {From = Vector2.new(X + Width, Y + Height), To = Vector2.new(X + Width, Y + Height - length)}
                    }
                    
                    for i = 1, 8 do
                        local lData = lines[i]
                        local main = box.Main[i]
                        local out = box.Outline[i]
                        
                        main.From = lData.From
                        main.To = lData.To
                        main.Color = color
                        main.Visible = true
                        
                        out.From = lData.From
                        out.To = lData.To
                        out.Visible = true
                    end
                else
                    HidePlayerESP(box)
                end
            else
                if ESP_Cache[Player] then
                    HidePlayerESP(ESP_Cache[Player])
                end
            end
        end)
        
        if not success then
            Roles_Cache[Player] = nil
        end
    end
end

local function AutoClearCache()
    Roles_Cache = {}
    for _, Player in pairs(PlayersService:GetPlayers()) do
        if ESP_Cache[Player] then
            HidePlayerESP(ESP_Cache[Player])
        end
    end
end

workspace.ChildAdded:Connect(AutoClearCache)
PlayersService.PlayerRemoving:Connect(RemoveESP)
RunService.RenderStepped:Connect(UpdateESP)

