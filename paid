-- ==========================================
spawn(function()
    local Workspace = game:GetService("Workspace")
    local RunService = game:GetService("RunService")
    local CoreGui = game:GetService("CoreGui")
    
    local ESPFolder = Instance.new("Folder")
    ESPFolder.Name = "MM2_CleanBlueGun_ESP"
    ESPFolder.Parent = CoreGui
    
    local lastUpdate = 0
    
    RunService.Heartbeat:Connect(function(delta)
        lastUpdate = lastUpdate + delta
        if lastUpdate < 0.15 then return end
        lastUpdate = 0
        
        if _G.GunESPEnabled then
            local droppedGun = nil
            local gun = Workspace:FindFirstChild("GunDrop")
            if gun then
                droppedGun = gun
            else
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj.Name == "GunDrop" then
                        droppedGun = obj
                        break
                    end
                end
            end
            
            if not droppedGun then
                ESPFolder:ClearAllChildren()
                return
            end
            
            local meshPart = droppedGun:FindFirstChildWhichIsA("BasePart") or droppedGun
            if not meshPart then
                ESPFolder:ClearAllChildren()
                return
            end
            
            for _, child in ipairs(ESPFolder:GetChildren()) do
                if child:IsA("Configuration") then
                    local adornment = child:FindFirstChildWhichIsA("SphereHandleAdornment")
                    if adornment and adornment.Adornee ~= meshPart then
                        child:Destroy()
                    end
                end
            end
            
            local existing = nil
            for _, child in ipairs(ESPFolder:GetChildren()) do
                if child:IsA("Configuration") then
                    local adornment = child:FindFirstChildWhichIsA("SphereHandleAdornment")
                    if adornment and adornment.Adornee == meshPart then
                        existing = child
                        break
